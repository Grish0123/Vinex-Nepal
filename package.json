{
  "name": "vinex-nepal",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --open /products",
    "dev:server": "node --env-file=.env server/index.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start:server": "node --env-file=.env server/index.js"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "nodemailer": "^6.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
